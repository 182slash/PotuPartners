# ─────────────────────────────────────────────────────────────────────────────
# PotuPartners Backend — Environment Variables
# Copy to .env and fill in all values before starting the server
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# Comma-separated list of allowed CORS origins
# Must exactly match frontend domain (no trailing slash)
CORS_ORIGIN=https://potupartners.site

# ─── PostgreSQL (DigitalOcean Managed Database) ───────────────────────────────
# Full connection string with SSL
DATABASE_URL=postgresql://doadmin:AVNS_xxxxx@db-postgresql-sgp1-xxxxx.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# CRITICAL: Use cryptographically random strings of at least 64 characters
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_64_character_random_hex_string_here_NEVER_use_this_placeholder
JWT_REFRESH_SECRET=replace_with_different_64_character_random_hex_string_NEVER_use_this

# Token expiration durations (standard time string format)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── DigitalOcean Spaces (S3-Compatible Object Storage) ──────────────────────
# Create a Space at: cloud.digitalocean.com/spaces
# Create API keys at: cloud.digitalocean.com/account/api/spaces
DO_SPACES_KEY=your_spaces_access_key_id
DO_SPACES_SECRET=your_spaces_secret_access_key
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_BUCKET=potupartners-files
DO_SPACES_CDN_URL=https://potupartners-files.sgp1.cdn.digitaloceanspaces.com

# ─── RAG Microservice (Internal) ─────────────────────────────────────────────
# Internal URL — not exposed publicly, only accessible within the VPS
RAG_SERVICE_URL=http://127.0.0.1:8000

# Shared secret between Node.js backend and Python RAG service
# Generate with: openssl rand -hex 32
RAG_SERVICE_SECRET=replace_with_32_character_random_hex_for_internal_service_auth

# ─── Security ─────────────────────────────────────────────────────────────────
# bcrypt rounds (higher = slower hashing, more secure; 12 is recommended for production)
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
